<!DOCTYPE html>
<html>
<head>
    <title>IIUI Journal - Blogs</title>
    <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-6V8P3VJLEF"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-6V8P3VJLEF');
</script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: Arial, Helvetica, sans-serif; 
            background: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .header {
            background: #3b5998;
            padding: 15px 0;
        }
        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header h1 {
            color: white;
            font-size: 24px;
        }
        .header a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
        }
        .header a:hover { text-decoration: underline; }
        /* Menu toggle - hidden by default on desktop */
.menu-toggle {
    display: none;
    color: white;
    font-size: 28px;
    cursor: pointer;
    padding: 5px 10px;
    user-select: none;
}
        .main {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
            flex: 1;
            width: 100%;
        }
        .page-header {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .page-header h2 { color: #333; }
        .button {
            display: inline-block;
            padding: 10px 20px;
            background: #3b5998;
            color: white;
            text-decoration: none;
            border-radius: 4px;
        }
        .button:hover { background: #0052a3; }
        .blogs-list { list-style: none; }
        .blog-item {
            padding: 25px;
            border: 1px solid #eee;
            margin-bottom: 20px;
            border-radius: 4px;
        }
        .blog-title {
            font-size: 22px;
            color: #3b5998;
            margin-bottom: 10px;
        }
        .blog-meta {
            color: #666;
            font-size: 14px;
            margin-bottom: 15px;
        }
        .blog-content {
            color: #333;
            line-height: 1.6;
            white-space: pre-wrap;
        }
        
/* Footer */
.footer {
    text-align: center;
    padding: 20px;
    color: #000000;
    font-size: 14px;
    border-top: 1px solid #e9ebee;
    margin-top: 30px;
    position: relative;
}

.footer small {
    display: block;
    margin-bottom: 5px;
}

.footer-text {
    color: #000000;
    font-size: 13px;
    margin-bottom: 10px;
}

.footer-links {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
}

.footer-links a {
    color: #000000;
    text-decoration: none;
    margin-left: 20px;
    font-size: 13px;
}

.footer-links a:hover {
    text-decoration: underline;
}

/* Mobile responsive styles */
@media screen and (max-width: 768px) {
    .header-content {
        flex-wrap: wrap;
    }
    
    .nav-links {
        display: none;
        width: 100%;
        flex-direction: column;
        margin-top: 15px;
        gap: 10px;
    }
    
    .nav-links.active {
        display: flex;
    }
    
    .nav-links a {
        margin: 0;
        padding: 12px 0;
        border-top: 1px solid rgba(255,255,255,0.2);
    }
    
    .menu-toggle {
        display: block;
        color: white;
        font-size: 24px;
        cursor: pointer;
        padding: 5px 10px;
    }
    
    .welcome {
        flex-direction: column;
        gap: 15px;
        align-items: flex-start;
    }
    
    .button {
        width: 30%;
        text-align: center;
    }
    
    .papers-grid {
        grid-template-columns: 1fr !important;
    }
    
    .contact-container {
        grid-template-columns: 1fr !important;
    }
    
    .post-card, .replies-section, .form-container {
        padding: 20px !important;
    }
    
    .post-title {
        font-size: 24px !important;
    }
    
    .reply-item {
        padding: 12px !important;
    }
    
    textarea, input, select {
        font-size: 16px !important; /* Prevents zoom on mobile */
    }
    
    .btn-group {
        flex-direction: column;
        gap: 10px;
    }
    
    .btn {
        width: 100%;
        text-align: center;
    }
    
    .modal-content {
        max-width: 95%;
        max-height: 80%;
    }
    .footer {
        position: relative;
        padding-bottom: 50px;
    }
    
    .footer-links {
        position: absolute;
        right: 50%;
        bottom: 10px;
        top: auto;
        transform: translateX(50%);
        width: 100%;
        text-align: center;
    }
    
    .footer-links a {
        margin: 0 10px;
    }
}
    </style>
</head>
<body>
    <div class="header">
        <div class="header-content">
            <h1>IIUI Journal</h1>
            <div class="menu-toggle" onclick="toggleMenu()">☰</div>
            <div class="nav-links" id="navLinks">
                <a href="/home">Home</a>
                <a href="/announcements">Announcements</a>
                <a href="/blogs">Blogs</a>
                <a href="/past-papers">Past Papers</a>
                <a href="/logout">Logout</a>
            </div>
        </div>
    </div>
    
    <div class="main">
        <div class="page-header">
            <h2>Blog Posts</h2>
            <a href="/blog/new" class="button">Write Blog</a>
        </div>
        
        <% 
        // Pakistan Time Helper Function for Blogs
        function pakistanTime(date) {
            if (!date) return '';
            const d = new Date(date);
            // Add 5 hours for Pakistan (UTC+5)
            d.setHours(d.getHours() + 5);
            
            const options = {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                hour12: true
            };
            return d.toLocaleString('en-PK', options);
        }
        %>
        
        <ul class="blogs-list">
            <% blogs.forEach(blog => { %>
                <li class="blog-item">
                    <h3 class="blog-title"><%= blog.title %></h3>
                    <div class="blog-meta">
                        By <%= blog.email %> • 
                        <%= pakistanTime(blog.created_at) %>
                    </div>
                    <div class="blog-content">
                        <%= blog.content %>
                    </div>
                </li>
            <% }) %>
        </ul>
    </div>
    
    <!-- Footer -->
    <div class="footer">
        <small>© 2026 IIUI Journal</small>
        <div class="footer-text">A Sabtain Ali production</div>
        <div class="footer-links">
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="/privacy">Privacy Policy</a>
        </div>
    </div>
    <script>
        function toggleMenu() {
            var navLinks = document.getElementById('navLinks');
            navLinks.classList.toggle('active');
        }
        
        // Close menu when clicking outside
        document.addEventListener('click', function(event) {
            var navLinks = document.getElementById('navLinks');
            var menuToggle = document.querySelector('.menu-toggle');
            
            if (!navLinks.contains(event.target) && !menuToggle.contains(event.target)) {
                navLinks.classList.remove('active');
            }
        });
        
        // Close menu on window resize if screen becomes larger
        window.addEventListener('resize', function() {
            if (window.innerWidth > 768) {
                document.getElementById('navLinks').classList.remove('active');
            }
        });
        </script>
</body>
</html>