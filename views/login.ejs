<!DOCTYPE html>
<html>
<head>
    <title>IIUI Journal - Login</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: Arial, Helvetica, sans-serif; 
            background: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .container { 
            width: 400px; 
            padding: 40px 20px;
            margin: 0 auto;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        h1 { color: #3b5998; margin-bottom: 30px; text-align: center; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 5px; color: #333; }
        input { 
            width: 100%; 
            padding: 10px; 
            border: 1px solid #ddd; 
            border-radius: 4px; 
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 12px;
            background: #3b5998;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
        }
        button:hover { background: #0052a3; }
        .error { 
            color: #cc0000; 
            margin-bottom: 20px; 
            padding: 10px; 
            background: #ffeeee; 
            border-radius: 4px; 
        }
        .link { 
            text-align: center; 
            margin-top: 20px; 
        }
        .link a { 
            color: #3b5998; 
            text-decoration: none; 
        }
        .link a:hover { text-decoration: underline; }
        
/* Footer */
.footer {
    text-align: center;
    padding: 20px;
    color: #000000;
    font-size: 14px;
    border-top: 1px solid #e9ebee;
    margin-top: 30px;
    position: relative;
}

.footer small {
    display: block;
    margin-bottom: 5px;
}

.footer-text {
    color: #000000;
    font-size: 13px;
    margin-bottom: 10px;
}

.footer-links {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
}

.footer-links a {
    color: #000000;
    text-decoration: none;
    margin-left: 20px;
    font-size: 13px;
}

.footer-links a:hover {
    text-decoration: underline;
}

/* Responsive */
@media (max-width: 700px) {
    .footer {
        position: relative;
        padding-bottom: 50px;
    }
    
    .footer-links {
        position: absolute;
        right: 50%;
        bottom: 10px;
        top: auto;
        transform: translateX(50%);
        width: 100%;
        text-align: center;
    }
    
    .footer-links a {
        margin: 0 10px;
    }
}
    </style>
</head>
<body>
    <div class="container">
        <h1>IIUI Journal</h1>
        
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        
        <form method="POST" action="/login">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required>
            </div>
            
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required>
            </div>
            
            <button type="submit">Login</button>
        </form>
        
        <div class="link">
            Don't have an account? <a href="/signup">Sign up</a>
        </div>
    </div>
    
    <!-- Footer -->
    <div class="footer">
        <small>© 2026 IIUI Journal</small>
        <div class="footer-text">A Sabtain Ali production</div>
        <div class="footer-links">
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="/privacy">Privacy Policy</a>
        </div>
    </div>
</body>
</html>